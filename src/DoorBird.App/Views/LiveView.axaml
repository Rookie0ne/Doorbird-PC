<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DoorBird.App.ViewModels"
             x:Class="DoorBird.App.Views.LiveView"
             x:DataType="vm:LiveViewModel">
    <DockPanel>
        <!-- Normal mode: bottom controls -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6"
                    Margin="0,10" HorizontalAlignment="Center"
                    IsVisible="{Binding !IsMaximized}">
            <Button Command="{Binding ToggleListenCommand}" Width="40" Height="36"
                    ToolTip.Tip="Listen to device audio" ToolTip.Placement="Top"
                    Background="{Binding IsListening, Converter={x:Static vm:LiveViewModel.BoolToBrush}}"
                    HorizontalContentAlignment="Center">
                <Panel>
                    <TextBlock Text="&#x1F508;" FontSize="18" IsVisible="{Binding !IsListening}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x1F50A;" FontSize="18" IsVisible="{Binding IsListening}" HorizontalAlignment="Center"/>
                </Panel>
            </Button>
            <Button Command="{Binding ToggleTalkCommand}" Width="40" Height="36"
                    ToolTip.Tip="Talk through device speaker" ToolTip.Placement="Top"
                    Background="{Binding IsTalking, Converter={x:Static vm:LiveViewModel.BoolToBrush}}"
                    HorizontalContentAlignment="Center">
                <Panel>
                    <TextBlock Text="&#x1F399;" FontSize="18" IsVisible="{Binding !IsTalking}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x1F3A4;" FontSize="18" IsVisible="{Binding IsTalking}" HorizontalAlignment="Center"/>
                </Panel>
            </Button>
            <Rectangle Width="1" Fill="Gray" Margin="2,4"/>
            <Button Command="{Binding OpenDoorCommand}" Width="40" Height="36"
                    ToolTip.Tip="Open door relay" ToolTip.Placement="Top" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F6AA;" FontSize="18"/>
            </Button>
            <Button Command="{Binding LightOnCommand}" Width="40" Height="36"
                    ToolTip.Tip="Turn on IR light" ToolTip.Placement="Top" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F4A1;" FontSize="18"/>
            </Button>
            <Button Command="{Binding RefreshCommand}" Width="40" Height="36"
                    ToolTip.Tip="Refresh image" ToolTip.Placement="Top" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F504;" FontSize="18"/>
            </Button>
            <Rectangle Width="1" Fill="Gray" Margin="2,4"/>
            <Button Command="{Binding ScreenshotCommand}" Width="40" Height="36"
                    ToolTip.Tip="Save screenshot to recording path" ToolTip.Placement="Top" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F4F7;" FontSize="18"/>
            </Button>
            <Button Command="{Binding ToggleRecordCommand}" Width="40" Height="36"
                    ToolTip.Tip="Record video and audio to MP4" ToolTip.Placement="Top"
                    HorizontalContentAlignment="Center"
                    Background="{Binding IsRecording, Converter={x:Static vm:LiveViewModel.BoolToBrush}}">
                <Panel>
                    <TextBlock Text="&#x23FA;" FontSize="18" Foreground="Red" IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x23F9;" FontSize="18" Foreground="White" IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
                </Panel>
            </Button>
            <Rectangle Width="1" Fill="Gray" Margin="2,4"/>
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="4,0" FontSize="12"/>
            <Button Command="{Binding ToggleMaximizeCommand}" Width="40" Height="36"
                    ToolTip.Tip="Maximize video view" ToolTip.Placement="Top" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x26F6;" FontSize="18"/>
            </Button>
        </StackPanel>

        <!-- Maximized mode: right-side vertical controls (30% larger) -->
        <StackPanel DockPanel.Dock="Right" Spacing="10" Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsMaximized}">
            <Button Command="{Binding ToggleListenCommand}" Width="57" Height="47"
                    ToolTip.Tip="Listen to device audio"
                    Background="{Binding IsListening, Converter={x:Static vm:LiveViewModel.BoolToBrush}}"
                    HorizontalContentAlignment="Center">
                <Panel>
                    <TextBlock Text="&#x1F508;" FontSize="23" IsVisible="{Binding !IsListening}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x1F50A;" FontSize="23" IsVisible="{Binding IsListening}" HorizontalAlignment="Center"/>
                </Panel>
            </Button>
            <Button Command="{Binding ToggleTalkCommand}" Width="57" Height="47"
                    ToolTip.Tip="Talk through device speaker"
                    Background="{Binding IsTalking, Converter={x:Static vm:LiveViewModel.BoolToBrush}}"
                    HorizontalContentAlignment="Center">
                <Panel>
                    <TextBlock Text="&#x1F399;" FontSize="23" IsVisible="{Binding !IsTalking}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x1F3A4;" FontSize="23" IsVisible="{Binding IsTalking}" HorizontalAlignment="Center"/>
                </Panel>
            </Button>
            <Separator Margin="0,3"/>
            <Button Command="{Binding OpenDoorCommand}" Width="57" Height="47"
                    ToolTip.Tip="Open door relay" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F6AA;" FontSize="23"/>
            </Button>
            <Button Command="{Binding LightOnCommand}" Width="57" Height="47"
                    ToolTip.Tip="Turn on IR light" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F4A1;" FontSize="23"/>
            </Button>
            <Separator Margin="0,3"/>
            <Button Command="{Binding ScreenshotCommand}" Width="57" Height="47"
                    ToolTip.Tip="Save screenshot to recording path" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x1F4F7;" FontSize="23"/>
            </Button>
            <Button Command="{Binding ToggleRecordCommand}" Width="57" Height="47"
                    ToolTip.Tip="Record video and audio to MP4"
                    HorizontalContentAlignment="Center"
                    Background="{Binding IsRecording, Converter={x:Static vm:LiveViewModel.BoolToBrush}}">
                <Panel>
                    <TextBlock Text="&#x23FA;" FontSize="23" Foreground="Red" IsVisible="{Binding !IsRecording}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x23F9;" FontSize="23" Foreground="White" IsVisible="{Binding IsRecording}" HorizontalAlignment="Center"/>
                </Panel>
            </Button>
            <Separator Margin="0,3"/>
            <Button Command="{Binding ToggleMaximizeCommand}" Width="57" Height="47"
                    ToolTip.Tip="Restore normal view" Background="Transparent"
                    HorizontalContentAlignment="Center">
                <TextBlock Text="&#x2716;" FontSize="18"/>
            </Button>
        </StackPanel>

        <!-- Video -->
        <Image Source="{Binding CurrentImage}" Stretch="Uniform"/>
    </DockPanel>
</UserControl>
